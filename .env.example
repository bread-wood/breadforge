# breadforge environment variables
# Copy to .env in your project root or export in your shell profile (~/.zshrc / ~/.zprofile).
#
#   export ANTHROPIC_API_KEY=sk-ant-...
#   export BREADFORGE_GH_TOKEN=ghp_...

# Required credentials
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub token for the yeast-bot service account (needs repo + workflow scopes).
# Build agents authenticate to GitHub as yeast-bot using this token.
BREADFORGE_GH_TOKEN=your-yeast-bot-github-token-here

# Optional — defaults shown
# BREADFORGE_MODEL=claude-sonnet-4-6
# BREADFORGE_CONCURRENCY=3
# BREADFORGE_AGENT_TIMEOUT_MINUTES=60
# BREADFORGE_WATCHDOG_INTERVAL_SECONDS=60
# BREADFORGE_MAX_RETRIES=3
# BREADFORGE_BEADS_DIR=~/.breadforge/beads
# BREADFORGE_RESEARCH_BACKEND=anthropic
# BREADFORGE_PLAN_BACKEND=anthropic
